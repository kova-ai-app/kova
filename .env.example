# =============================================================================
# KOVA — Environment Variables
# =============================================================================
# Copy this file to .env.local (web), .env (worker), and fill in real values.
# Never commit .env or .env.local files.
#
# Sections:
#   1. Clerk (Auth)
#   2. Database (Neon)
#   3. Redis (Upstash)
#   4. Audio Storage (Cloudflare R2)
#   5. AI Services
#   6. Error Monitoring (BetterStack)
#   7. Internal
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Clerk (Auth)
# https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------

# Web (Next.js)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Mobile (Expo) — same keys, different prefix
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Webhook secret (Clerk Dashboard → Webhooks → Signing secret)
CLERK_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# 2. Database (Neon Postgres)
# https://console.neon.tech → Connection string
# Use the "pooled" connection string for Vercel (serverless)
# Use the "direct" connection string for drizzle-kit migrations
# -----------------------------------------------------------------------------

# Pooled (used by web API routes in production)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Direct (used by drizzle-kit for migrations)
DATABASE_URL_UNPOOLED=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# 3. Redis (Upstash)
# https://console.upstash.com → your database → Connect → ioredis tab
# Use the rediss:// URL (TLS is required by Upstash)
# -----------------------------------------------------------------------------

REDIS_URL=rediss://default:password@sharp-mink-12345.upstash.io:6379

# -----------------------------------------------------------------------------
# 4. Audio Storage (Cloudflare R2 — S3-compatible)
# Cloudflare dashboard → R2 → Manage R2 API Tokens → Create token
# S3_ENDPOINT = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Buckets: kova-audio-prod (production), kova-audio-dev (development)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=auto        # R2: use "auto"; for AWS S3 use e.g. "us-east-1"
S3_BUCKET_NAME=kova-audio-dev
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com

# -----------------------------------------------------------------------------
# 5. AI Services
# -----------------------------------------------------------------------------

# Deepgram (Transcription — Nova-3 Multilingual)
# https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=...

# LLM provider selection (env-var driven — no code changes needed to switch)
# Supported values: openai | anthropic | google | groq | openrouter
LLM_PROVIDER=openai
# Model ID for the chosen provider (e.g. gpt-4o-mini, claude-3-haiku-20240307)
LLM_MODEL=gpt-4o-mini

# OpenAI — https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# Anthropic — https://console.anthropic.com → API Keys (set if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Google Generative AI — https://aistudio.google.com → API Keys (set if LLM_PROVIDER=google)
GOOGLE_GENERATIVE_AI_API_KEY=...

# Groq — https://console.groq.com → API Keys (set if LLM_PROVIDER=groq)
GROQ_API_KEY=gsk_...

# OpenRouter — https://openrouter.ai → API Keys (set if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...

# -----------------------------------------------------------------------------
# 6. Error Monitoring (BetterStack — Sentry-SDK compatible)
# https://betterstack.com → Logs & Telemetry → your source → DSN
# -----------------------------------------------------------------------------

# Web (used by sentry.server.config.ts and sentry.client.config.ts)
SENTRY_DSN=https://...@in.logs.betterstack.com/...
NEXT_PUBLIC_SENTRY_DSN=https://...@in.logs.betterstack.com/...

# Optional: enables source map uploads to Sentry during CI/production builds
# These are only needed if you re-enable Sentry source map upload in next.config.mjs
# SENTRY_ORG=kova
# SENTRY_PROJECT=kova-web
# SENTRY_AUTH_TOKEN=sntrys_...

# Mobile
EXPO_PUBLIC_SENTRY_DSN=https://...@in.logs.betterstack.com/...

# Worker (placeholder — Sentry SDK not yet initialized in worker)
SENTRY_DSN_WORKER=https://...@in.logs.betterstack.com/...

# -----------------------------------------------------------------------------
# 7. Internal
# -----------------------------------------------------------------------------

# Environment tag (development | staging | production)
APP_ENV=development

# Web base URL (used for generating API links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mobile app base URL (set in apps/mobile/.env)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Worker API URL (web calls worker indirectly via BullMQ; this is for health checks)
WORKER_INTERNAL_URL=http://localhost:3001

# Bull Board job monitoring (worker internal — not publicly accessible)
BULL_BOARD_PORT=3001
