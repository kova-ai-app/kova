# =============================================================================
# KOVA — Environment Variables
# =============================================================================
# Copy this file to .env.local (web), .env (worker), and fill in real values.
# Never commit .env or .env.local files.
#
# Sections:
#   1. Clerk (Auth)
#   2. Database (Neon)
#   3. Redis (Railway)
#   4. AWS S3 (Audio storage)
#   5. AI Services
#   6. Sentry
#   7. Internal
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Clerk (Auth)
# https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------

# Web (Next.js)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Mobile (Expo) — same keys, different prefix
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Webhook secret (Clerk Dashboard → Webhooks → Signing secret)
CLERK_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# 2. Database (Neon Postgres)
# https://console.neon.tech → Connection string
# Use the "pooled" connection string for Vercel (serverless)
# Use the "direct" connection string for drizzle-kit migrations
# -----------------------------------------------------------------------------

# Pooled (used by web API routes in production)
DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Direct (used by drizzle-kit for migrations)
DATABASE_URL_UNPOOLED=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# 3. Redis (Railway)
# Railway dashboard → your Redis service → Connect → REDIS_URL
# -----------------------------------------------------------------------------

REDIS_URL=redis://default:password@monorail.proxy.rlwy.net:PORT

# -----------------------------------------------------------------------------
# 4. AWS S3 (Audio Storage)
# IAM user: kova-app-user
# Buckets: kova-audio-prod (production), kova-audio-dev (development)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET_NAME=kova-audio-dev

# -----------------------------------------------------------------------------
# 5. AI Services
# -----------------------------------------------------------------------------

# Deepgram (Transcription — Nova-3 Multilingual)
# https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=...

# OpenAI (Scoring — GPT-5.4-mini)
# https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# 6. Sentry
# https://sentry.io → Project Settings → Client Keys (DSN)
# -----------------------------------------------------------------------------

# Web
SENTRY_DSN=https://...@o...ingest.sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@o...ingest.sentry.io/...
SENTRY_ORG=kova
SENTRY_PROJECT=kova-web
SENTRY_AUTH_TOKEN=sntrys_...

# Mobile
EXPO_PUBLIC_SENTRY_DSN=https://...@o...ingest.sentry.io/...

# Worker
SENTRY_DSN_WORKER=https://...@o...ingest.sentry.io/...

# -----------------------------------------------------------------------------
# 7. Internal
# -----------------------------------------------------------------------------

# Environment tag (development | staging | production)
APP_ENV=development

# Web base URL (used for generating API links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker API URL (web calls worker indirectly via BullMQ; this is for health checks)
WORKER_INTERNAL_URL=http://localhost:3001
